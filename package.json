{
  "name": "double-eighteen-react",
  "version": "0.4.2",
  "description": "React components for double-eighteen — dominoes, trains, and the Mexican Train hub. Headless rules/AI/layout live in the double-eighteen package.",
  "license": "MIT",
  "author": "Digital Defiance, Jessica Mulein",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@warp12/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "dominoes",
    "mexican-train",
    "double-nine",
    "double-twelve",
    "double-fifteen",
    "double-eighteen",
    "react",
    "components",
    "game",
    "board-game",
    "chicken-foot"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digital-Defiance/double-eighteen-react.git"
  },
  "bugs": {
    "url": "https://github.com/Digital-Defiance/double-eighteen-react/issues"
  },
  "homepage": "https://github.com/Digital-Defiance/double-eighteen-react#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build --config vite.config.mts",
    "build:lib": "vite build --config vite.config.mts",
    "test": "vitest run --config vite.config.mts",
    "test:watch": "vitest --config vite.config.mts",
    "test:coverage": "vitest run --config vite.config.mts --coverage",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint src",
    "dev": "vite --config vite.demo.config.mts",
    "demo:build": "vite build --config vite.demo.config.mts",
    "demo:preview": "vite preview --config vite.demo.config.mts",
    "prepack": "yarn build:lib",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "double-eighteen": ">=0.4.2",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "double-eighteen": "^0.4.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jsdom": "^27.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.0",
    "sass": "^1.97.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "~4.1.0"
  },
  "packageManager": "yarn@4.17.0"
}
